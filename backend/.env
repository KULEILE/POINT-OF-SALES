# ============================================================
# K-POINT OF SALES — Environment Variables (Railway)
# ============================================================

# ============================================================
# DATABASE (Railway PostgreSQL)
# ============================================================

# Primary connection string (RECOMMENDED - use this)
DATABASE_URL=postgresql://postgres:fDFXVDZTmmvfteiNrePgCKYuNbXgflOH@sakura.proxy.rlwy.net:30303/railway

# Individual database variables (alternative)
DB_HOST=sakura.proxy.rlwy.net
DB_PORT=30303
DB_NAME=railway
DB_USER=postgres
DB_PASS=fDFXVDZTmmvfteiNrePgCKYuNbXgflOH

# ============================================================
# JWT AUTHENTICATION
# ============================================================

# Change this to a strong random string in production
JWT_SECRET=kpoint_jwt_secret_change_this_to_a_strong_random_string_2025
JWT_EXPIRES_IN=8h

# ============================================================
# SERVER
# ============================================================

PORT=5000
NODE_ENV=production

# ============================================================
# CORS - Frontend URLs
# ============================================================

# Primary frontend
FRONTEND_URL=https://kpos-frontend.onrender.com

# Local development (optional)
FRONTEND_URL_DEV=http://localhost:3000
FRONTEND_URL_DEV2=http://localhost:5173

# ============================================================
# BCRYPT
# ============================================================

BCRYPT_ROUNDS=12

# ============================================================
# SESSION & SECURITY (Optional)
# ============================================================

# Session timeout in seconds (8 hours)
SESSION_TIMEOUT=28800

# Maximum file upload size (in MB)
MAX_FILE_SIZE=10

# Rate limiting (requests per minute)
RATE_LIMIT=100

# ============================================================
# CORS ALLOWED ORIGINS (for server.js)
# ============================================================

# If you want to use environment variable for CORS
ALLOWED_ORIGINS=https://kpos-frontend.onrender.com,https://localhost:3000,http://localhost:5173

# ============================================================
# LOGGING (Optional)
# ============================================================

# Enable detailed logging
LOG_LEVEL=info

# Enable request logging
REQUEST_LOGGING=true

# ============================================================
# EMAIL (Optional - if you add email functionality)
# ============================================================

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@kpos.com

# ============================================================
# PAYMENT GATEWAY (Optional)
# ============================================================

# PAYMENT_SECRET_KEY=your_payment_key
# PAYMENT_PUBLIC_KEY=your_public_key